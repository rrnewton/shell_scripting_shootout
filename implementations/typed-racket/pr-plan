#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
entrypoint="$root/main.rkt"
compiled="$root/compiled/main_rkt.zo"
stamp="$root/compiled/pr-plan-build.stamp"
lock="$root/.pr-plan-build.lock"

command -v raco >/dev/null 2>&1 || {
  echo "pr-plan: error: raco is not installed" >&2
  exit 127
}
command -v racket >/dev/null 2>&1 || {
  echo "pr-plan: error: racket is not installed" >&2
  exit 127
}

source_fingerprint() {
  {
    racket --version
    find "$root" -maxdepth 1 -type f -name '*.rkt' -print0 \
      | sort -z \
      | xargs -0 sha256sum
  } | sha256sum | cut -d' ' -f1
}

needs_build() {
  expected=$1
  if [ ! -f "$compiled" ] || [ ! -f "$stamp" ]; then
    return 0
  fi
  [ "$(cat "$stamp")" != "$expected" ]
}

fingerprint=$(source_fingerprint)
while needs_build "$fingerprint"; do
  if mkdir "$lock" 2>/dev/null; then
    trap 'rmdir "$lock" 2>/dev/null || true' 0 1 2 3 15
    fingerprint=$(source_fingerprint)
    if needs_build "$fingerprint"; then
      raco make "$entrypoint"
      printf '%s\n' "$fingerprint" >"$stamp"
    fi
    rmdir "$lock"
    trap - 0 1 2 3 15
  else
    attempts=0
    while [ -d "$lock" ] && [ "$attempts" -lt 6000 ]; do
      sleep 0.05
      attempts=$((attempts + 1))
    done
    if [ -d "$lock" ]; then
      echo "pr-plan: error: timed out waiting for build lock $lock" >&2
      exit 1
    fi
  fi
  fingerprint=$(source_fingerprint)
done

exec racket "$entrypoint" "$@"
