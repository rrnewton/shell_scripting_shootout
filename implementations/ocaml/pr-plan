#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
binary="$root/_build/default/src/main.exe"
build_stamp="$root/_build/pr-plan-build.stamp"
build_lock="$root/.pr-plan-build.lock"

if command -v opam >/dev/null 2>&1; then
  eval "$(opam env --set-switch 2>/dev/null)"
fi
command -v dune >/dev/null 2>&1 || {
  echo "pr-plan: error: dune is not installed" >&2
  exit 127
}
command -v ocamlc >/dev/null 2>&1 || {
  echo "pr-plan: error: ocamlc is not installed" >&2
  exit 127
}

source_fingerprint() {
  {
    ocamlc -version
    dune --version
    find "$root/src" "$root/test" -type f \
      \( -name '*.ml' -o -name '*.mli' -o -name 'dune' \) -print0 \
      | sort -z \
      | xargs -0 sha256sum
    sha256sum "$root/dune-project" "$root/pr_plan.opam"
  } | sha256sum | cut -d' ' -f1
}

needs_build() {
  expected=$1
  if [ ! -x "$binary" ] || [ ! -f "$build_stamp" ]; then
    return 0
  fi
  [ "$(cat "$build_stamp")" != "$expected" ]
}

fingerprint=$(source_fingerprint)
while needs_build "$fingerprint"; do
  if mkdir "$build_lock" 2>/dev/null; then
    trap 'rmdir "$build_lock" 2>/dev/null || true' 0 1 2 3 15
    fingerprint=$(source_fingerprint)
    if needs_build "$fingerprint"; then
      dune build --root "$root" --display quiet src/main.exe
      printf '%s\n' "$fingerprint" >"$build_stamp"
    fi
    rmdir "$build_lock"
    trap - 0 1 2 3 15
  else
    attempts=0
    while [ -d "$build_lock" ] && [ "$attempts" -lt 6000 ]; do
      sleep 0.05
      attempts=$((attempts + 1))
    done
    if [ -d "$build_lock" ]; then
      echo "pr-plan: error: timed out waiting for the build lock $build_lock" >&2
      exit 1
    fi
  fi
  fingerprint=$(source_fingerprint)
done

exec "$binary" "$@"
