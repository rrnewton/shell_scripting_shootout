#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${BUN_BIN:-}" ]]; then
  bun_bin="$BUN_BIN"
elif command -v bun >/dev/null 2>&1; then
  bun_bin="$(command -v bun)"
elif [[ -x "$HOME/.bun/bin/bun" ]]; then
  bun_bin="$HOME/.bun/bin/bun"
else
  printf '%s\n' 'error: Bun is not installed or discoverable via BUN_BIN, PATH, or ~/.bun/bin/bun' >&2
  exit 127
fi

exec "$bun_bin" run "$(dirname "${BASH_SOURCE[0]}")/src/cli.ts" "$@"
