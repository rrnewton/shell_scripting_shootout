FROM docker.io/oven/bun:1.3.14@sha256:e10577f0db68676a7024391c6e5cb4b879ebd17188ab750cf10024a6d700e5c4

USER root
RUN apt-get update \
    && apt-get install --yes --no-install-recommends git python3 time \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY . .

RUN cd implementations/typescript-bun \
    && bun install --frozen-lockfile \
    && bun run check

CMD ["python3", "harness/conformance.py", "--candidate", "typescript-bun", "--require", "typescript-bun"]
