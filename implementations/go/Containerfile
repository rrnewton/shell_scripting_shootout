FROM docker.io/library/golang:1.26.4-bookworm@sha256:b305420a68d0f229d91eb3b3ed9e519fcf2cf5461da4bef997bf927e8c0bfd2b

RUN apt-get update \
    && apt-get install -y --no-install-recommends git python3 time \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY . .

RUN rm -rf implementations/go/.cache \
    && cd implementations/go \
    && go test ./... \
    && cd /work \
    && python3 harness/conformance.py --candidate go --require go

CMD ["python3", "harness/conformance.py", "--candidate", "go", "--require", "go"]
